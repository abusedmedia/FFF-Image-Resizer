{
  "name": "root",
  "private": true,
  "scripts": {
    "preinstall": "npx npm-force-resolutions",
    "clean_deps": "find . -type d -name \"node_modules\" -exec rm -rf {} + -o -type f -name \"package-lock.json\" -exec rm -f {} +",
    "upgrade": "lernaupdate",

    "frontend": "cd packages/frontend && npm run dev",
    "backend": "cd packages/backend && npm run dev",
    "backend:deploy": "cd packages/backend && npm run deploy"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "lerna": "^8.1.3",
    "lerna-update-wizard": "^1.1.2",
    "npm-force-resolutions": "^0.0.10"
  },
  "overrides": {
    "escaper": "latest"
  }
}
